%lh
<%= "%xc" -%>
<%= t('compliments.comps_title', :name => char.name.upcase) -%>
<%= "%xn"  %>

<% paginator.page_items.each do |c| -%>
<% if c.scene_id %>
<%= "%xcFrom "  -%>
<%=  c.from -%>
<%= " for Scene "  -%>
<%=  c.scene_id -%>
<% else %>
<%= "%xcFrom "  -%>
<%=  c.from -%>
<% end %>
<%=  right(date(c), 65 ) -%>
<%= "%xn"  %>
<%=  c.comp_msg %>

<% end %>
<%= paginator.page_footer %>
